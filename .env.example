# ETH Flow Index (EFI) Configuration
# Copy this file to .env and fill in your API keys

# CoinGecko API Key (optional - free tier works without key)
# Get one at: https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Etherscan API Key (recommended for better rate limits)
# Get one at: https://etherscan.io/apis
ETHERSCAN_API_KEY=

# Beaconcha.in API Key (optional)
# Get one at: https://beaconcha.in/api
BEACONCHAIN_API_KEY=

# Dune Analytics API Key (optional - for exchange flow data)
# Get one at: https://dune.com/settings/api
DUNE_API_KEY=
